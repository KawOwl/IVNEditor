#
# Langfuse 自部署环境变量示例
#
# 使用：
#   cp .env.example .env
#   然后填入真实值（生成随机值的命令见下）
#
# 生成随机值的命令：
#   openssl rand -hex 32      # 用于 NEXTAUTH_SECRET / ENCRYPTION_KEY
#   openssl rand -hex 16      # 用于 SALT
#   openssl rand -base64 24   # 用于密码
#

# ─── 对外访问 ────────────────────────────────────────────────
# 部署服务器 IP 或域名 + 端口，用于 langfuse web UI 的 canonical URL
NEXTAUTH_URL=http://your-server-ip:3000

# 宿主机暴露的端口（默认 3000）
LANGFUSE_WEB_PORT=3000

# 宿主机绑定的 IP。默认 127.0.0.1 只通 loopback，外部访问需 SSH 隧道或反向代理。
# 真想公网暴露改为 0.0.0.0 + 改 LANGFUSE_WEB_PORT 为非标高位端口 + 配 HTTPS
LANGFUSE_WEB_BIND=127.0.0.1

# ─── 加密 & 会话密钥 ─────────────────────────────────────────
SALT=CHANGEME_random_hex_16
ENCRYPTION_KEY=CHANGEME_random_hex_32
NEXTAUTH_SECRET=CHANGEME_random_hex_32

# ─── 内部服务密码（仅 docker network 内访问，但仍要安全） ───
POSTGRES_PASSWORD=CHANGEME_postgres_password
CLICKHOUSE_PASSWORD=CHANGEME_clickhouse_password
REDIS_AUTH=CHANGEME_redis_password
MINIO_ROOT_PASSWORD=CHANGEME_minio_password

# ─── 首次启动自动初始化（已存在则跳过，不会覆盖） ───────────
# 如果这些值留空，得手动登录 web UI 点击创建
LANGFUSE_INIT_ORG_ID=ivn-org
LANGFUSE_INIT_ORG_NAME=IVN
LANGFUSE_INIT_PROJECT_ID=ivn-engine
LANGFUSE_INIT_PROJECT_NAME=IVN Engine

# API key 必须以 pk-lf- / sk-lf- 开头。自定义值就行，首次启动时写入 DB
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-ivn-CHANGEME
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-ivn-CHANGEME

# 管理员账号（登录 web UI 用）
LANGFUSE_INIT_USER_EMAIL=admin@ivn.local
LANGFUSE_INIT_USER_NAME=IVN Admin
LANGFUSE_INIT_USER_PASSWORD=CHANGEME_admin_password
