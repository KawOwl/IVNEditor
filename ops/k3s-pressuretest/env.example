# k3s 压测环境配置
# 复制为 env 并填实际值：cp env.example env
# ⚠️ 不要把填好的 env 文件 commit 进 git（.gitignore 已加）

# ============================================================
# 阿里云 RDS PostgreSQL
# ============================================================
PG_HOST=pgm-wzxxxxxxxxxxxxxx.pg.rds.aliyuncs.com
PG_PORT=5432
PG_USER=langfuse_user
PG_PASSWORD=CHANGEME
# 两个 database 都在同一个 RDS 实例里，先手动 CREATE DATABASE
PG_LANGFUSE_DB=langfuse
PG_IVN_DB=ivn

# ============================================================
# 阿里云 ClickHouse 社区兼容版
# ============================================================
CH_HOST=cc-wzxxxxxxxxxx.public.clickhouse.ads.aliyuncs.com
CH_USER=langfuse
CH_PASSWORD=CHANGEME

# ============================================================
# 阿里云 Redis 开源版
# ============================================================
REDIS_HOST=r-wzxxxxxxxxxxxxxx.redis.rds.aliyuncs.com
REDIS_PORT=6379
REDIS_PASSWORD=CHANGEME

# ============================================================
# 阿里云 OSS
# ============================================================
OSS_BUCKET=ivn-langfuse-prod
OSS_REGION=cn-shenzhen
# 用 internal endpoint，避免公网流量费
OSS_ENDPOINT=oss-cn-shenzhen-internal.aliyuncs.com
OSS_AK=LTAI5xxxxxxxxxxxxx
OSS_SK=CHANGEME

# ============================================================
# Langfuse 初始管理员
# ============================================================
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_PASSWORD=CHANGEME
LANGFUSE_INIT_USER_NAME=Admin

# 留空脚本会自动 openssl rand 生成（首次部署后记下来，重装时填回来保持一致）
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
LANGFUSE_ENCRYPTION_KEY=

# ============================================================
# ACR（阿里云容器镜像服务）拉取凭证
# ============================================================
# VPC 内网地址（ECS 上 k3s 拉镜像用）
ACR_SERVER=registry-vpc.cn-shenzhen.aliyuncs.com
# 阿里云账号（完整邮箱或账号 ID）
ACR_USERNAME=your-aliyun-account
# ACR 控制台 → 访问凭证 → 固定密码（不是阿里云登录密码）
ACR_PASSWORD=CHANGEME

# ============================================================
# IVN 引擎
# ============================================================
# 镜像地址（用 VPC 内网地址，ECS pull 免流量费 + 秒级）
IVN_IMAGE=registry-vpc.cn-shenzhen.aliyuncs.com/ivn-prod/engine:v1

# admin 账号（格式：username:password;username:password）
IVN_ADMIN_USERS=admin:CHANGEME

# PG 连接池大小（每个 replica）
PG_POOL_MAX=40

# 如果 Langfuse 已经配过 project，填这里；否则留空，事后手动更新 secret
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
