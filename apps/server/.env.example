# Server port
PORT=3001

# LLM Configuration (API Key stays on server, never exposed to frontend)
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat
LLM_NAME=deepseek

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/ivn_engine
# Optional PostgreSQL tuning
# PG_SSL=off
# PG_POOL_MAX=30
# PG_CONNECT_TIMEOUT_MS=15000

# Memory provider integrations
# MEM0_API_KEY=

# Langfuse (可观测性 — 部署见 ops/langfuse/README.md)
# 三个字段任意一个为空则观测功能静默关闭，不影响业务
# 注意：千万不要在 KEY=VALUE 后面加行内注释！
#   systemd EnvironmentFile parser 不识别行内 #，会把注释整段读进 value
#   bun 的 parser 能处理，但 systemd 不行——两边行为不一致踩过坑
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# S3-compatible storage (M4 资产 pipeline)
#   本地 dev：用 MinIO（见 ops/minio/README.md 一键起）
#   生产/共享 dev：阿里云 OSS（S3 兼容端点）
#
# MinIO 配置（默认示例）
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345
S3_BUCKET=ivn-assets
# MinIO 需 true（path-style），阿里云 OSS 需 false（virtual-hosted）
S3_FORCE_PATH_STYLE=true
#
# 阿里云 OSS 模板（取消注释并填 region/AK/SK/bucket）：
# S3_ENDPOINT=oss-cn-<region>.aliyuncs.com         # 无 scheme 会自动补 https://
# S3_REGION=cn-<region>                             # 例 cn-hangzhou / cn-shenzhen
# S3_ACCESS_KEY_ID=<AK>
# S3_SECRET_ACCESS_KEY=<SK>
# S3_BUCKET=<bucket>
# S3_FORCE_PATH_STYLE=false
