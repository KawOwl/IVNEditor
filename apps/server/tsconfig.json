{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "../..",
    "paths": {
      "@ivn/core/*": ["../../packages/core/src/*"],
      "@ivn/specification/*": ["../../packages/specification/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "scripts/**/*",
    "drizzle.config.ts",
    "../../packages/core/src/**/*",
    "../../packages/specification/src/**/*"
  ],
  "exclude": [
    "../../packages/core/src/**/__tests__/**",
    "../../packages/core/src/**/*.test.ts",
    "../../packages/specification/src/**/__tests__/**",
    "../../packages/specification/src/**/*.test.ts"
  ]
}
