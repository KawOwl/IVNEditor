/**
 * extract-scenario.mts —— 从线上 server 抽出剧本，生成 typed scenario .mts
 *
 * 用法：
 *   SCRIPT_API_URL=https://staging.../api \
 *   SCRIPT_API_TOKEN=eyJ... \
 *   SCRIPT_ID=xxx \
 *   bun packages/core/scripts/evals/extract-scenario.mts
 *
 * 可选 env：
 *   VERSION_ID=...        指定版本（默认 published 优先 / fallback latest draft）
 *   OUTPUT_ID=foo         覆盖输出文件名 / export 名前缀（默认 SCRIPT_ID）
 *   OUTPUT_DIR=/path      覆盖输出目录（默认 scripts/evals/scenarios/）
 *
 * 输出：scripts/evals/scenarios/<OUTPUT_ID>.mts
 *
 * persona / goal 留 TODO 占位，用户手填。生成后建议跑 pnpm typecheck
 * 验证 manifest 数据形状跟 type 定义对得上。
 */

import { mkdir } from 'node:fs/promises';
import path from 'node:path';
import { fileURLToPath } from 'node:url';

import { requireEnv } from './_helpers.mts';
import type { ScriptManifest } from '#internal/types';

interface ExtractInputs {
  readonly baseUrl: string;
  readonly scriptId: string;
  readonly versionId: string | undefined;
  readonly authToken: string | undefined;
}

const inputs: ExtractInputs = {
  baseUrl: requireEnv('SCRIPT_API_URL'),
  scriptId: requireEnv('SCRIPT_ID'),
  versionId: Bun.env.VERSION_ID,
  authToken: Bun.env.SCRIPT_API_TOKEN,
};
const outputId = Bun.env.OUTPUT_ID ?? inputs.scriptId;
const outputDir = Bun.env.OUTPUT_DIR
  ?? path.join(path.dirname(fileURLToPath(import.meta.url)), 'scenarios');
const outputPath = path.join(outputDir, `${sanitizeFilename(outputId)}.mts`);

const manifest = await fetchFullManifest(inputs);
const code = renderScenarioModule(outputId, manifest);

await mkdir(outputDir, { recursive: true });
await Bun.write(outputPath, code);

console.log(`✓ wrote ${outputPath}`);
console.log(`  scriptId=${inputs.scriptId}${inputs.versionId ? ` versionId=${inputs.versionId}` : ''}`);
console.log(`  segments=${manifest.chapters.flatMap((ch) => ch.segments).length}`);
console.log('');
console.log('Next steps:');
console.log(`  1. 编辑 ${outputPath} 填 persona.goal / style`);
console.log(`  2. 写 entry: scripts/evals/${outputId}-{scripted,simulator}.mts`);
console.log(`  3. 跑 pnpm typecheck 验证 generated 代码`);

async function fetchFullManifest(opts: ExtractInputs): Promise<ScriptManifest> {
  const url = new URL('/api/ops/script.get_full_manifest', opts.baseUrl).toString();
  const headers: Record<string, string> = { 'Content-Type': 'application/json' };
  if (opts.authToken) headers['Authorization'] = `Bearer ${opts.authToken}`;

  const response = await fetch(url, {
    method: 'POST',
    headers,
    body: JSON.stringify({
      scriptId: opts.scriptId,
      ...(opts.versionId ? { versionId: opts.versionId } : {}),
    }),
  });
  if (!response.ok) {
    const detail = await response.text();
    throw new Error(`HTTP ${response.status} ${response.statusText}: ${detail}`);
  }

  const payload = (await response.json()) as {
    ok: boolean;
    data?: { manifest: ScriptManifest };
    code?: string;
    message?: string;
  };
  if (!payload.ok || !payload.data) {
    throw new Error(`Op failed: ${payload.code ?? 'UNKNOWN'} - ${payload.message ?? ''}`);
  }
  return payload.data.manifest;
}

function renderScenarioModule(outputId: string, manifest: ScriptManifest): string {
  const characters = manifest.characters ?? [];
  const backgrounds = manifest.backgrounds ?? [];
  const segments = manifest.chapters.flatMap((ch) => ch.segments);
  const exportName = camelCase(outputId);

  return `/**
 * Scenario "${outputId}" —— extracted from live script ${manifest.id}
 *
 * Source label: ${escapeForBlockComment(manifest.label)}
 * Generated by scripts/evals/extract-scenario.mts; manual edits OK.
 */

import type { LiveMemoryEvaluationOptions } from '#internal/evaluation/memory-harness';
import { buildParserManifest } from '#internal/narrative-parser-v2';
import type {
  BackgroundAsset,
  CharacterAsset,
  MemoryConfig,
  PromptSegment,
  ScriptManifest,
  StateSchema,
} from '#internal/types';
import type { PlayerPersona } from '#internal/evaluation/player-simulator';

const characters: CharacterAsset[] = ${jsonLiteral(characters)};

const backgrounds: BackgroundAsset[] = ${jsonLiteral(backgrounds)};

const stateSchema: StateSchema = ${jsonLiteral(manifest.stateSchema)};

const segments: PromptSegment[] = ${jsonLiteral(segments)};

const parserSourceManifest = { characters, backgrounds } satisfies Pick<ScriptManifest, 'characters' | 'backgrounds'>;

export const ${exportName}Scenario: LiveMemoryEvaluationOptions['scenario'] = {
  id: ${jsonLiteral(outputId)},
  segments,
  stateSchema,
  initialPrompt: ${jsonLiteral(manifest.initialPrompt ?? '')},
  enabledTools: ${jsonLiteral(manifest.enabledTools)},
  tokenBudget: 24000,
  defaultScene: ${jsonLiteral(manifest.defaultScene ?? { background: null, sprites: [] })},
  protocolVersion: ${jsonLiteral(manifest.protocolVersion ?? 'v2-declarative-visual')},
  parserManifest: buildParserManifest(parserSourceManifest),
  characters,
  backgrounds,
};

export const ${exportName}MemoryConfig: MemoryConfig = ${jsonLiteral(manifest.memoryConfig)};

/** TODO: 填入这个剧本的 player goal / style，让 simulator 知道怎么扮演。*/
export const ${exportName}Persona: Omit<PlayerPersona, 'llmConfig'> = {
  goal: 'TODO: 描述玩家在本剧本里要达成的目标',
  style: 'TODO（可选）: 玩家说话风格',
};
`;
}

function jsonLiteral(value: unknown): string {
  return JSON.stringify(value, null, 2);
}

/** kebab-case / snake_case / dot.case → camelCase。"silver-key" → "silverKey"。*/
function camelCase(id: string): string {
  return id
    .split(/[-_/.]+/)
    .filter(Boolean)
    .map((part, i) =>
      i === 0
        ? part.charAt(0).toLowerCase() + part.slice(1)
        : part.charAt(0).toUpperCase() + part.slice(1).toLowerCase(),
    )
    .join('');
}

function sanitizeFilename(id: string): string {
  return id.replace(/[^a-zA-Z0-9._-]/g, '-');
}

function escapeForBlockComment(text: string): string {
  return text.replace(/\*\//g, '*\\/');
}
