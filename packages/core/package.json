{
  "name": "@ivn/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.mts",
  "types": "./src/index.mts",
  "imports": {
    "#internal/narrative-parser-v2": "./src/narrative-parser-v2/index.mts",
    "#internal/narrative-parser-v2/*": "./src/narrative-parser-v2/*.mts",
    "#internal/narrative-rewrite": "./src/narrative-rewrite/index.mts",
    "#internal/narrative-rewrite/*": "./src/narrative-rewrite/*.mts",
    "#internal/narrative-retry-main": "./src/narrative-retry-main/index.mts",
    "#internal/narrative-retry-main/*": "./src/narrative-retry-main/*.mts",
    "#internal/v3": "./src/v3/index.mts",
    "#internal/v3/*": "./src/v3/*.mts",
    "#internal/v3/kernel": "./src/v3/kernel/index.mts",
    "#internal/v3/kernel/*": "./src/v3/kernel/*.mts",
    "#internal/*": "./src/*.mts"
  },
  "exports": {
    ".": {
      "types": "./src/index.mts",
      "import": "./src/index.mts",
      "default": "./src/index.mts"
    },
    "./narrative-parser-v2": {
      "types": "./src/narrative-parser-v2/index.mts",
      "import": "./src/narrative-parser-v2/index.mts",
      "default": "./src/narrative-parser-v2/index.mts"
    },
    "./narrative-parser-v2/*": {
      "types": "./src/narrative-parser-v2/*.mts",
      "import": "./src/narrative-parser-v2/*.mts",
      "default": "./src/narrative-parser-v2/*.mts"
    },
    "./narrative-rewrite": {
      "types": "./src/narrative-rewrite/index.mts",
      "import": "./src/narrative-rewrite/index.mts",
      "default": "./src/narrative-rewrite/index.mts"
    },
    "./narrative-rewrite/*": {
      "types": "./src/narrative-rewrite/*.mts",
      "import": "./src/narrative-rewrite/*.mts",
      "default": "./src/narrative-rewrite/*.mts"
    },
    "./narrative-retry-main": {
      "types": "./src/narrative-retry-main/index.mts",
      "import": "./src/narrative-retry-main/index.mts",
      "default": "./src/narrative-retry-main/index.mts"
    },
    "./narrative-retry-main/*": {
      "types": "./src/narrative-retry-main/*.mts",
      "import": "./src/narrative-retry-main/*.mts",
      "default": "./src/narrative-retry-main/*.mts"
    },
    "./evaluation/*": {
      "types": "./src/evaluation/*.mts",
      "import": "./src/evaluation/*.mts",
      "default": "./src/evaluation/*.mts"
    },
    "./v3": {
      "types": "./src/v3/index.mts",
      "import": "./src/v3/index.mts",
      "default": "./src/v3/index.mts"
    },
    "./v3/*": {
      "types": "./src/v3/*.mts",
      "import": "./src/v3/*.mts",
      "default": "./src/v3/*.mts"
    },
    "./v3/kernel": {
      "types": "./src/v3/kernel/index.mts",
      "import": "./src/v3/kernel/index.mts",
      "default": "./src/v3/kernel/index.mts"
    },
    "./v3/kernel/*": {
      "types": "./src/v3/kernel/*.mts",
      "import": "./src/v3/kernel/*.mts",
      "default": "./src/v3/kernel/*.mts"
    },
    "./*": {
      "types": "./src/*.mts",
      "import": "./src/*.mts",
      "default": "./src/*.mts"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit && tsgo --noEmit -p scripts/tsconfig.json",
    "typecheck:tsc": "tsc --noEmit && tsc --noEmit -p scripts/tsconfig.json",
    "test": "bun test",
    "eval:memory:live": "bun --env-file ../../apps/server/.env scripts/memory-live-eval.mts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "ai": "^6.0.168",
    "htmlparser2": "^12.0.0",
    "mem0ai": "^3.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.2.18",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "typescript": "^6.0.2"
  }
}
