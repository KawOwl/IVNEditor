{
  "name": "ivn-server",
  "version": "0.1.0",
  "description": "Interactive Novel Engine — Backend Server",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "bun x tsc --noEmit",
    "db:generate": "bun drizzle-kit generate",
    "db:push": "bun drizzle-kit push",
    "db:studio": "bun drizzle-kit studio",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.37",
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/static": "^1.4.7",
    "ai": "^6.0.141",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.2.25",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.2.18",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.0"
  }
}
