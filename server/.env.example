# Server port
PORT=3001

# LLM Configuration (API Key stays on server, never exposed to frontend)
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat
LLM_NAME=deepseek

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/ivn_engine
